{
  "name": "@virastack/password-toggle",
  "version": "1.0.2",
  "description": "Fully accessible and customizable password visibility hook for React.",
  "author": {
    "name": "Ömer Gülçiçek (ViraStack)",
    "email": "iletisim@omergulcicek.com",
    "url": "https://omergulcicek.com"
  },
  "license": "MIT",
  "homepage": "https://virastack.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virastack/password-toggle.git"
  },
  "bugs": {
    "url": "https://github.com/virastack/password-toggle/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc"
  },
  "keywords": [
    "virastack",
    "react",
    "hook",
    "password-toggle",
    "password-visibility",
    "accessibility",
    "a11y",
    "form-validation",
    "dx"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
